# Postgres (Railway: add a Postgres service, then in the app service set
# DATABASE_URL = ${{Postgres.DATABASE_URL}} as a variable reference)
DATABASE_URL="postgresql://user:pass@host:5432/railway"

# Google OAuth (Google Cloud Console > Credentials > OAuth 2.0 Client ID, type: Web)
# Authorized redirect URI: https://YOUR-APP.up.railway.app/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Base URL of the deployed app (Railway public domain)
APP_URL="https://YOUR-APP.up.railway.app"

# Secret protecting the cron endpoints (any long random string; the built-in
# scheduler in server.js sends it automatically)
CRON_SECRET=""

# Simple dashboard password
DASHBOARD_PASSWORD=""
